[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 = "res://global/gdextension/game/target/debug/libgame.so"
linux.release.x86_64 = "res://global/gdextension/game/target/release/libgame.so"
windows.debug.x86_64 = "res://global/gdextension/game/target/debug/game.dll"
windows.release.x86_64 = "res://global/gdextension/game/target/release/game.dll"